<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Coepd.Mobile.MainPage"
             Title="COEPD Leads"
             BackgroundColor="#F4F7FB">
    <Grid RowDefinitions="Auto,*">
        <Border Margin="16,16,16,10"
                Padding="18"
                Background="#0F172A"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24">
            <VerticalStackLayout Spacing="14">
                <VerticalStackLayout Spacing="4">
                    <Label Text="COEPD Lead Viewer"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Login with your staff or admin account to view generated leads."
                           FontSize="13"
                           TextColor="#CBD5E1" />
                </VerticalStackLayout>

                <Entry Placeholder="Website URL"
                       Text="{Binding BaseUrl}"
                       Keyboard="Url"
                       BackgroundColor="#FFFFFF"
                       ClearButtonVisibility="WhileEditing" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Entry Grid.Column="0"
                           Placeholder="Email"
                           Text="{Binding Email}"
                           Keyboard="Email"
                           BackgroundColor="#FFFFFF"
                           ClearButtonVisibility="WhileEditing" />
                    <Entry Grid.Column="1"
                           Placeholder="Password"
                           Text="{Binding Password}"
                           IsPassword="True"
                           BackgroundColor="#FFFFFF"
                           ClearButtonVisibility="WhileEditing" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="Login"
                            Clicked="OnLoginClicked"
                            BackgroundColor="#22C55E"
                            TextColor="White"
                            CornerRadius="16"
                            HeightRequest="50" />
                    <Button Grid.Column="1"
                            Text="Refresh"
                            Clicked="OnRefreshClicked"
                            BackgroundColor="#2563EB"
                            TextColor="White"
                            CornerRadius="16"
                            HeightRequest="50" />
                    <Button Grid.Column="2"
                            Text="Logout"
                            Clicked="OnLogoutClicked"
                            BackgroundColor="#E2E8F0"
                            TextColor="#0F172A"
                            CornerRadius="16"
                            HeightRequest="50" />
                </Grid>

                <Label Text="{Binding StatusMessage}"
                       TextColor="#E2E8F0"
                       FontSize="13" />
            </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="1" Margin="16,0,16,16" RowDefinitions="Auto,Auto,*">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Entry Grid.Column="0"
                       Placeholder="Search by name, phone, email, location"
                       Text="{Binding SearchText}"
                       Completed="OnSearchCompleted"
                       BackgroundColor="White"
                       ClearButtonVisibility="WhileEditing" />
                <Button Grid.Column="1"
                        Text="Search"
                        Clicked="OnSearchClicked"
                        BackgroundColor="#0EA5E9"
                        TextColor="White"
                        CornerRadius="14" />
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,12,0,12" ColumnSpacing="12">
                <Border Padding="16" Background="#FFFFFF" Stroke="#D8E2F0" StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Total Leads" FontSize="12" TextColor="#64748B" />
                        <Label Text="{Binding TotalLeads}" FontSize="24" FontAttributes="Bold" TextColor="#0F172A" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Padding="16" Background="#FFFFFF" Stroke="#D8E2F0" StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Session" FontSize="12" TextColor="#64748B" />
                        <Label Text="{Binding SessionRole}" FontSize="18" FontAttributes="Bold" TextColor="#0F172A" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <CollectionView Grid.Row="2"
                            ItemsSource="{Binding Leads}"
                            SelectionMode="Single"
                            SelectionChanged="OnLeadSelected">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24" Spacing="8">
                        <Label Text="No leads to show yet."
                               HorizontalTextAlignment="Center"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#0F172A" />
                        <Label Text="Login first, then refresh to load the latest generated leads from your website."
                               HorizontalTextAlignment="Center"
                               TextColor="#64748B" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="16"
                                Background="#FFFFFF"
                                Stroke="#D8E2F0"
                                StrokeShape="RoundRectangle 20">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#0F172A" />
                                    <Border Grid.Column="1"
                                            Padding="10,4"
                                            Background="#DCFCE7"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12">
                                        <Label Text="{Binding SourceLabel}"
                                               FontSize="11"
                                               TextColor="#166534" />
                                    </Border>
                                </Grid>
                                <Label Text="{Binding Phone}" TextColor="#0F172A" />
                                <Label Text="{Binding Email}" TextColor="#334155" />
                                <Label Text="{Binding Location}" TextColor="#475569" />
                                <Label Text="{Binding DateTimeDisplay}" FontSize="12" TextColor="#64748B" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
