<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="PrimaryColor">#0B1C2C</Color>
    <Color x:Key="AccentColor">#3B82F6</Color>
    <Color x:Key="BackgroundColor">#F5F7FB</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="MutedTextColor">#6B7280</Color>
    <Color x:Key="TealColor">#14B8A6</Color>
    <Color x:Key="AmberColor">#F59E0B</Color>
    <Color x:Key="SkyColor">#0EA5E9</Color>
    <Color x:Key="BorderColor">#E5E7EB</Color>
    <Color x:Key="InputBackgroundColor">#F8FAFC</Color>
    <Color x:Key="AppPageBackground">#F5F7FB</Color>
    <Color x:Key="AppSurface">#FFFFFF</Color>
    <Color x:Key="AppSurfaceMuted">#F8FAFC</Color>
    <Color x:Key="AppHeroBackground">#0B1C2C</Color>
    <Color x:Key="AppTextPrimary">#0B1C2C</Color>
    <Color x:Key="AppTextSecondary">#475569</Color>
    <Color x:Key="AppTextMuted">#6B7280</Color>
    <Color x:Key="AppAccentBlue">#3B82F6</Color>
    <Color x:Key="AppAccentBlueSoft">#DBEAFE</Color>
    <Color x:Key="AppAccentSlate">#334155</Color>
    <Color x:Key="AppAccentSlateSoft">#E2E8F0</Color>

    <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0B1C2C" Offset="0.0" />
        <GradientStop Color="#3B82F6" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ShimmerBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#E5E7EB" Offset="0.0" />
        <GradientStop Color="#F8FAFC" Offset="0.45" />
        <GradientStop Color="#E5E7EB" Offset="1.0" />
    </LinearGradientBrush>

    <Shadow x:Key="SoftShadow"
            Brush="#1A0B1C2C"
            Offset="0,8"
            Radius="20"
            Opacity="0.2" />

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BackgroundColor">
            <AppThemeBinding Light="{StaticResource BackgroundColor}" Dark="#0B1220" />
        </Setter>
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor">
            <AppThemeBinding Light="{StaticResource CardColor}" Dark="#111827" />
        </Setter>
        <Setter Property="Shell.ForegroundColor">
            <AppThemeBinding Light="{StaticResource PrimaryColor}" Dark="#E5E7EB" />
        </Setter>
        <Setter Property="Shell.TitleColor">
            <AppThemeBinding Light="{StaticResource PrimaryColor}" Dark="#E5E7EB" />
        </Setter>
        <Setter Property="Shell.DisabledColor" Value="#A8B0BB" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource MutedTextColor}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource CardColor}" />
        <Setter Property="Shell.TabBarForegroundColor">
            <AppThemeBinding Light="{StaticResource AccentColor}" Dark="#60A5FA" />
        </Setter>
        <Setter Property="Shell.TabBarTitleColor">
            <AppThemeBinding Light="{StaticResource AccentColor}" Dark="#60A5FA" />
        </Setter>
        <Setter Property="Shell.TabBarUnselectedColor">
            <AppThemeBinding Light="{StaticResource MutedTextColor}" Dark="#9CA3AF" />
        </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentColor}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="Padding" Value="20,14" />
        <Setter Property="Shadow" Value="{StaticResource SoftShadow}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup Name="CommonStates">
                    <VisualState Name="Normal" />
                    <VisualState Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.9" />
                            <Setter Property="Scale" Value="0.98" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="DarkButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Padding" Value="20,14" />
    </Style>

    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="BorderColor" Value="{StaticResource PrimaryColor}" />
        <Setter Property="BorderWidth" Value="1.5" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryColor}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Padding" Value="20,14" />
    </Style>

    <Style x:Key="CardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor">
            <AppThemeBinding Light="{StaticResource CardColor}" Dark="#111827" />
        </Setter>
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Padding" Value="22" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Shadow" Value="{StaticResource SoftShadow}" />
        <Setter Property="BorderColor" Value="#00000000" />
    </Style>

    <Style x:Key="AppCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardColor}" />
        <Setter Property="Stroke" Value="#00000000" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="Shadow" Value="{StaticResource SoftShadow}" />
    </Style>

    <Style x:Key="HeroFrame" TargetType="Frame">
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="22" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="BorderColor" Value="#00000000" />
        <Setter Property="Background" Value="{StaticResource HeroGradient}" />
        <Setter Property="Shadow" Value="{StaticResource SoftShadow}" />
    </Style>

    <Style x:Key="HeroCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HeroGradient}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 24" />
        <Setter Property="Shadow" Value="{StaticResource SoftShadow}" />
    </Style>

    <Style x:Key="InputFrame" TargetType="Frame">
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="14,13" />
        <Setter Property="BorderColor">
            <AppThemeBinding Light="{StaticResource BorderColor}" Dark="#1F2937" />
        </Setter>
        <Setter Property="BackgroundColor">
            <AppThemeBinding Light="{StaticResource InputBackgroundColor}" Dark="#0F172A" />
        </Setter>
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="BadgeFrame" TargetType="Frame">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="BorderColor" Value="#00000000" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor">
            <AppThemeBinding Light="{StaticResource PrimaryColor}" Dark="#F3F4F6" />
        </Setter>
        <Setter Property="LineHeight" Value="1.2" />
    </Style>

    <Style x:Key="MutedLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor">
            <AppThemeBinding Light="{StaticResource MutedTextColor}" Dark="#9CA3AF" />
        </Setter>
        <Setter Property="LineHeight" Value="1.4" />
    </Style>

    <Style x:Key="StatValue" TargetType="Label">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryColor}" />
        <Setter Property="LineHeight" Value="1.1" />
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}" />
    <Style x:Key="SecondaryActionButton" TargetType="Button" BasedOn="{StaticResource DarkButton}" />
    <Style x:Key="DangerActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource DangerColor}" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="14,8" />
    </Style>

    <Style x:Key="FormEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryColor}" />
        <Setter Property="PlaceholderColor" Value="#9CA3AF" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="MinimumHeightRequest" Value="52" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor">
            <AppThemeBinding Light="{StaticResource PrimaryColor}" Dark="#E5E7EB" />
        </Setter>
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="PlaceholderColor" Value="#9CA3AF" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor">
            <AppThemeBinding Light="{StaticResource PrimaryColor}" Dark="#E5E7EB" />
        </Setter>
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="ImageButton">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{StaticResource AccentColor}" />
    </Style>

    <ControlTemplate x:Key="ShimmerSkeletonTemplate">
        <Grid>
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    Background="#EEF2F7">
                <Grid>
                    <Border x:Name="ShimmerFill"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            Background="{StaticResource ShimmerBrush}"
                            TranslationX="-260" />
                </Grid>
            </Border>
        </Grid>
    </ControlTemplate>
</ResourceDictionary>
