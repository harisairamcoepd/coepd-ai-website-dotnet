<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:Coepd.Mobile.ViewModels"
             x:Class="Coepd.Mobile.Views.DashboardPage"
             x:DataType="viewModels:DashboardViewModel"
             BackgroundColor="{DynamicResource BackgroundColor}"
             Shell.NavBarIsVisible="False">
    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsLoading}">
        <ScrollView>
            <VerticalStackLayout Padding="20,20,20,32" Spacing="18">
                <Frame Style="{StaticResource HeroFrame}">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Label Text="COEPD Dashboard" TextColor="White" FontSize="24" FontAttributes="Bold" />
                            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                <Ellipse x:Name="LiveDot" WidthRequest="8" HeightRequest="8" Fill="#22C55E" />
                                <Label Text="LIVE" TextColor="#D1FAE5" FontSize="12" FontAttributes="Bold" />
                            </HorizontalStackLayout>
                            <Button Grid.Column="2" Text="Logout" Clicked="OnLogoutClicked" BackgroundColor="#22FFFFFF" TextColor="White" CornerRadius="12" FontAttributes="Bold" FontSize="12" Padding="12,8" Margin="12,0,0,0" />
                        </Grid>
                        <Frame Style="{StaticResource BadgeFrame}" BackgroundColor="#19FFFFFF" HorizontalOptions="Start">
                            <Label Text="{Binding RoleBadgeText}" TextColor="White" FontSize="11" FontAttributes="Bold" />
                        </Frame>
                        <Label Text="{Binding RoleSubtitle}" TextColor="#D7E8FF" FontSize="14" LineHeight="1.4" />
                        <Label>
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Live view: " TextColor="White" />
                                    <Span Text="{Binding TotalLeads}" TextColor="White" FontAttributes="Bold" />
                                    <Span Text=" total, " TextColor="White" />
                                    <Span Text="{Binding TodayLeads}" TextColor="White" FontAttributes="Bold" />
                                    <Span Text=" today..." TextColor="White" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label Text="Auto-refresh every 5 seconds" TextColor="#0EA5E9" FontSize="13" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Frame>

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="14" RowSpacing="14">
                    <Frame Grid.Row="0" Grid.Column="0" Style="{StaticResource CardFrame}" BackgroundColor="#F8FBFF">
                        <VerticalStackLayout Spacing="12">
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 2" HeightRequest="3" BackgroundColor="#0B1C2C" />
                            <Label Text="Overview" FontSize="12" TextColor="#6B7280" FontAttributes="Bold" />
                            <Label Text="{Binding TotalLeads}" Style="{StaticResource StatValue}" TextColor="#0B1C2C" />
                            <Label Text="TOTAL LEADS" FontSize="11" TextColor="#6B7280" FontAttributes="Bold" />
                            <Label Text="All live inbound records" FontSize="11" TextColor="#6B7280" />
                            <Label Text="{Binding TotalTrendText}" TextColor="{Binding TotalTrendColor}" FontSize="12" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Row="0" Grid.Column="1" Style="{StaticResource CardFrame}" BackgroundColor="#EEF5FF">
                        <VerticalStackLayout Spacing="12">
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 2" HeightRequest="3" BackgroundColor="#3B82F6" />
                            <Label Text="Today" FontSize="12" TextColor="#6B7280" FontAttributes="Bold" />
                            <Label Text="{Binding TodayLeads}" Style="{StaticResource StatValue}" TextColor="#3B82F6" />
                            <Label Text="TODAY" FontSize="11" TextColor="#6B7280" FontAttributes="Bold" />
                            <Label Text="Fresh leads since midnight" FontSize="11" TextColor="#6B7280" />
                            <Label Text="{Binding TodayTrendText}" TextColor="{Binding TodayTrendColor}" FontSize="12" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Row="1" Grid.Column="0" Style="{StaticResource CardFrame}" BackgroundColor="#ECFDF8">
                        <VerticalStackLayout Spacing="12">
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 2" HeightRequest="3" BackgroundColor="#14B8A6" />
                            <Label Text="Chatbot" FontSize="12" TextColor="#6B7280" FontAttributes="Bold" />
                            <Label Text="{Binding ChatbotLeads}" Style="{StaticResource StatValue}" TextColor="#14B8A6" />
                            <Label Text="CHATBOT" FontSize="11" TextColor="#6B7280" FontAttributes="Bold" />
                            <Label Text="Assistant-generated leads" FontSize="11" TextColor="#6B7280" />
                            <Label Text="{Binding ChatbotTrendText}" TextColor="{Binding ChatbotTrendColor}" FontSize="12" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Row="1" Grid.Column="1" Style="{StaticResource CardFrame}" BackgroundColor="#FFF9EC">
                        <VerticalStackLayout Spacing="12">
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 2" HeightRequest="3" BackgroundColor="#F59E0B" />
                            <Label Text="Website" FontSize="12" TextColor="#6B7280" FontAttributes="Bold" />
                            <Label Text="{Binding WebsiteLeads}" Style="{StaticResource StatValue}" TextColor="#F59E0B" />
                            <Label Text="WEBSITE" FontSize="11" TextColor="#6B7280" FontAttributes="Bold" />
                            <Label Text="Direct website conversions" FontSize="11" TextColor="#6B7280" />
                            <Label Text="{Binding WebsiteTrendText}" TextColor="{Binding WebsiteTrendColor}" FontSize="12" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Quick Actions" Style="{StaticResource SectionTitle}" FontSize="20" />
                            <Label Text="Open lead operations or pull a fresh live sync." Style="{StaticResource MutedLabel}" />
                        </VerticalStackLayout>
                        <Button Text="Open Lead Explorer" Style="{StaticResource PrimaryButton}" Command="{Binding OpenLeadsCommand}" />
                        <Button Text="Refresh Dashboard" Style="{StaticResource OutlineButton}" Command="{Binding RefreshCommand}" />
                    </VerticalStackLayout>
                </Frame>

                <Label Text="Last sync kept active for your workspace feed." Style="{StaticResource MutedLabel}" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
