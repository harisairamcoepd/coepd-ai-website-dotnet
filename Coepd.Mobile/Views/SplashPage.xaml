<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Coepd.Mobile.Views.SplashPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#071124">
    <Grid>
        <VerticalStackLayout Spacing="18" VerticalOptions="Center" HorizontalOptions="Center">
            <Border Padding="24"
                    Background="#0E7490"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 32">
                <Label Text="COEPD"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center" />
            </Border>
            <Label Text="Lead Command Center"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
            <Label Text="Secure mobile access for admin and staff teams."
                   FontSize="14"
                   TextColor="#C7D2FE"
                   HorizontalTextAlignment="Center" />
            <ActivityIndicator IsRunning="True"
                               Color="#22C55E"
                               Margin="0,12,0,0" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
